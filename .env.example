# Copy this file to .env and fill in your values.
# The app reads these via environment variables — never commit .env to git.

# ── OBS WebSocket ───────────────────────────────────────────────────────
OBS_IP=192.168.1.100
OBS_PORT=4455
OBS_PASSWORD=your_obs_websocket_password

# ── Home Assistant ──────────────────────────────────────────────────────
# Full URL to your HA instance (no trailing slash)
HA_URL=http://192.168.1.100:8123
# Long-Lived Access Token from your HA profile page → scroll to bottom
HA_TOKEN=your_long_lived_access_token_here
